# Aegis Live Autonomous Agent — environment configuration
# Copy this file to .env and fill in your values:
#   cp demos/live_agent/.env.example demos/live_agent/.env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ACP Gateway URL (local dev default shown)
ACP_GATEWAY_URL=http://localhost:8000

# Your tenant UUID (visible in Settings → Tenant)
ACP_TENANT_ID=00000000-0000-0000-0000-000000000001

# API key created in Developer Panel → API Keys (starts with acp_)
ACP_API_KEY=acp_YOUR_KEY_HERE

# ── Optional ──────────────────────────────────────────────────────────────────

# Agent ID to attribute decisions to (defaults to the demo agent)
ACP_AGENT_ID=11111111-1111-1111-1111-111111111111

# How many task rounds to run (default: 3)
# ACP_ROUNDS=3

# Delay between tasks in seconds (default: 2)
# ACP_DELAY=2
