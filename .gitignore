# ==========================================
# Terraform — sprint-8 IaC
# ==========================================
# State and plan files contain provider tokens, generated passwords, and
# the full live AWS resource inventory. NEVER commit any of these.
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.*
infra/terraform/**/*.tfvars
infra/terraform/**/*.tfvars.json
infra/terraform/**/crash.log
infra/terraform/**/override.tf
infra/terraform/**/override.tf.json
infra/terraform/**/*_override.tf
infra/terraform/**/*_override.tf.json
# An empty backup is fine to track; but the .terraform/ directory shouldn't be:
infra/terraform/**/.terraformrc
infra/terraform/**/terraform.rc

# Phase-1 cleanup 2026-06-15. The patterns above only cover
# infra/terraform; tfstate/tfvars elsewhere (voice-agent/infrastructure,
# any future module) were a quiet risk — local audit found 4 .tfstate
# files under voice-agent/ that the per-module rule missed. Broaden so
# every tfstate / tfvars / .terraform/ in the tree is ignored.
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
**/*.tfvars.json
**/.terraform/
**/.terraform.lock.hcl

# Phase-1 cleanup 2026-06-15 — defensive: macOS finder cruft + Python
# build/cache that occasionally slipped past the per-module rules.
**/.DS_Store
**/__pycache__/
**/*.pyc
**/*.egg-info/

# Generated secret files (sprint-8.2 dev secrets path)
# We keep secrets locally at /tmp/aegis-dev-secrets/ — outside the repo —
# but also block any accidental in-repo creation.
**/aegis-dev-secrets/
**/dev-creds.env
**/prod-creds.env
**/*-creds.env
.env.pypi
