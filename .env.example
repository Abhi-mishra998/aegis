# ACP Environment Variables — TEMPLATE
# Copy to .env and fill in real values. .env is gitignored.
#
# Rotation policy:
#   - JWT_SECRET_KEY: rotate every 90 days, or immediately on suspected leak.
#     Regenerate with: python -c "import secrets; print(secrets.token_hex(32))"
#     IMPORTANT: must match in BOTH acp/.env AND acp/infra/.env or tokens break.
#   - INTERNAL_SECRET: rotate every 90 days; coordinated restart of all services required.
#   - GROQ_API_KEY: rotate immediately on suspected leak via the Groq console.
#   - DB passwords: rotate via init-db.sql + matching update to infra/userlist.txt.

# ── Infrastructure ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/acp
# Local dev: redis://localhost:6379/0
# AWS ElastiCache (TLS required): rediss://master.<cluster>.aps1.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379/0

# ── Database Passwords (MUST match infra/init-db.sql) ──────────────────────
REGISTRY_DB_PASSWORD=CHANGE_ME
IDENTITY_DB_PASSWORD=CHANGE_ME
AUDIT_DB_PASSWORD=CHANGE_ME
API_DB_PASSWORD=CHANGE_ME
USAGE_DB_PASSWORD=CHANGE_ME
# Runtime Trust Infrastructure DBs (added 2026-05-13)
IDENTITY_GRAPH_DB_PASSWORD=CHANGE_ME
FLIGHT_RECORDER_DB_PASSWORD=CHANGE_ME
AUTONOMY_DB_PASSWORD=CHANGE_ME

# ── Security / JWT ──────────────────────────────────────────────────────────
# 64-character hex. Regenerate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15

# ── External Integrations ───────────────────────────────────────────────────
OPA_URL=http://localhost:8181
OPA_FAIL_MODE=closed

# Inter-service auth. Treat as production-grade secret.
INTERNAL_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Optional: separate signing key for legacy HS256 service mesh JWTs (falls back
# to INTERNAL_SECRET). Sprint 1.4 introduces per-service ES256 keys via
# ACP_MESH_* below — use those for new deployments. MESH_JWT_SECRET stays only
# for back-compat during gradual rollout.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MESH_JWT_SECRET=

# Sprint 1.4 — per-service asymmetric mesh JWT keys (closes audit C12).
# Each service owns one ES256 (P-256) private key; verifiers hold every
# accepted service's public key. Leak of one service's key cannot forge
# another's tokens.
#
# ACP_MESH_SERVICE_NAME       — this process's identity (e.g. "gateway").
# ACP_MESH_PRIVATE_KEY_PEM    — base64-encoded ES256 PKCS8 PEM (this service).
# ACP_MESH_TRUSTED_KEYS       — JSON object {service_name: PEM (base64)} of
#                               every service whose tokens this process accepts.
# Generate a keypair with:
#   openssl ecparam -name prime256v1 -genkey -noout -out svc.pem
#   openssl ec -in svc.pem -pubout -out svc.pub.pem
ACP_MESH_SERVICE_NAME=
ACP_MESH_PRIVATE_KEY_PEM=
ACP_MESH_TRUSTED_KEYS=

# Sprint 1.3 — audit signing key custody (closes audit C9/S5).
# Default: LocalFileSigningKeyProvider (PEM on disk, dev only).
# Production: set RECEIPT_SIGNING_PROVIDER=ssm and point
# RECEIPT_SIGNING_SSM_PARAMETER at a SecureString in SSM Parameter Store
# (matches the existing /aegis-voice-guide/* convention).
#   RECEIPT_SIGNING_PROVIDER=ssm
#   RECEIPT_SIGNING_SSM_PARAMETER=/aegis-audit/receipt-signing-key
#   AWS_REGION=ap-south-1
# Required IAM: ssm:GetParameter + kms:Decrypt (for the SSM-encrypting CMK).
RECEIPT_SIGNING_PROVIDER=
RECEIPT_SIGNING_SSM_PARAMETER=
# Independent root-signing key (transparency Merkle roots). Same env shape.
ROOT_SIGNING_PROVIDER=
ROOT_SIGNING_SSM_PARAMETER=

# Groq inference (https://console.groq.com/keys)
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── Internal Service URLs (localhost for direct uvicorn runs) ──────────────
REGISTRY_SERVICE_URL=http://localhost:8001
IDENTITY_SERVICE_URL=http://localhost:8002
POLICY_SERVICE_URL=http://localhost:8003
AUDIT_SERVICE_URL=http://localhost:8004
API_SERVICE_URL=http://localhost:8005
USAGE_SERVICE_URL=http://localhost:8006
BEHAVIOR_SERVICE_URL=http://localhost:8007
DECISION_SERVICE_URL=http://localhost:8010
INSIGHT_SERVICE_URL=http://localhost:8011
FORENSICS_SERVICE_URL=http://localhost:8012
IDENTITY_GRAPH_SERVICE_URL=http://localhost:8013
FLIGHT_RECORDER_SERVICE_URL=http://localhost:8014
AUTONOMY_SERVICE_URL=http://localhost:8015

# ── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Observability ───────────────────────────────────────────────────────────
OTLP_ENDPOINT=

# ── Alerting webhooks (leave empty to disable) ─────────────────────────────
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated. Add prod origins here.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Rate Limits ─────────────────────────────────────────────────────────────
GLOBAL_RATE_LIMIT=10000
IP_RATE_LIMIT=1000
TENANT_RATE_LIMIT=1000
AGENT_RATE_LIMIT=100
TOKEN_RATE_LIMIT=200

# ── Gateway hot-path tunables ───────────────────────────────────────────────
# Backpressure semaphore on /execute (defaults are sane for the demo)
MAX_CONCURRENT_EXECUTION=500
MAX_PAYLOAD_BYTES=10000

# ── Decision service timeouts (seconds) ─────────────────────────────────────
# Registry leg
DECISION_REGISTRY_TIMEOUT_CONNECT=0.3
DECISION_REGISTRY_TIMEOUT_READ=0.6
DECISION_REGISTRY_TIMEOUT_WRITE=0.3
DECISION_REGISTRY_TIMEOUT_POOL=0.3
# Policy + behavior fan-out
DECISION_GATHER_TIMEOUT_CONNECT=0.3
DECISION_GATHER_TIMEOUT_READ=0.8
DECISION_GATHER_TIMEOUT_WRITE=0.3
DECISION_GATHER_TIMEOUT_POOL=0.3
DECISION_GATHER_TOTAL_TIMEOUT=1.0

# Grafana admin credentials (required — no default in docker-compose)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Upstream LLM keys (Path B proxy + agent runtime) ──────────────────────
# Anthropic Claude — the primary Aegis upstream provider. Read by
# services/gateway/routers/messages.py and the agent demos.
ANTHROPIC_API_KEY=
# OpenAI — only required if the Path B /v1/chat/completions proxy is
# enabled (services/gateway/routers/openai_messages.py).
OPENAI_API_KEY=

# ── Auth / Clerk (Sprint 1 SaaS self-serve) ───────────────────────────────
# ACP_AUTH_PROVIDER controls which validator the gateway runs:
#   legacy  → HS256 API-key tokens only (pre-Clerk)
#   clerk   → Clerk RS256 only (production SaaS)
#   both    → run both validators in parallel (rollout / shadow mode)
ACP_AUTH_PROVIDER=both
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_TEMPLATE=

# ── Stripe (Sprint 7 billing) ─────────────────────────────────────────────
# Operator-supplied. In production read from SSM:
#   /aegis-prodha/stripe/secret-key (etc.)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Slack OAuth (Sprint S2 — one-click Connect button) ────────────────────
# Get these from https://api.slack.com/apps after pasting
# infra/slack/manifest.yml. The redirect URI in the manifest must match
# PUBLIC_BASE_URL/sso/slack/callback.
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=

# ── Public deployment URL ────────────────────────────────────────────────
# The customer-facing base URL the gateway lives behind. Used by the
# Slack OAuth redirect_uri and any other absolute-URL generation.
# Local dev: http://localhost:8000 (default).
# Production: https://aegisagent.in (or the customer's HA endpoint).
PUBLIC_BASE_URL=http://localhost:8000

# ── Gateway-internal self-call (Sprint S4 demo + /execute pipeline) ───────
# The gateway sometimes calls its own /execute endpoint inside the
# request pipeline (demo workspace spawn, etc.). In docker-compose this
# is the inter-container DNS name; in production it's the ALB-internal
# endpoint or 127.0.0.1 inside the same pod.
INTERNAL_GATEWAY_URL=http://gateway:8000

# ── Receipt + Merkle signing (cryptographic chain) ────────────────────────
# Production sources the ed25519 PEM from SSM SecureString.
RECEIPT_SIGNING_PROVIDER=ssm
RECEIPT_SIGNING_SSM_PARAMETER=/aegis-audit/receipt-signing-key
ROOT_SIGNING_SSM_PARAMETER=/aegis-audit/root-signing-key
