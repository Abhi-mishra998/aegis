# ── AWS Production Environment ───────────────────────────────────────────────
# Fill in every REPLACE_ME value. Copy to infra/.env on the EC2 server.
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"

# Infrastructure — RDS and ElastiCache (NOT localhost)
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_RDS_PASSWORD@REPLACE_RDS_ENDPOINT:5432/acp
REDIS_URL=redis://REPLACE_ELASTICACHE_ENDPOINT:6379/0

# Postgres details (for init-db.sql and pgbouncer)
POSTGRES_HOST=REPLACE_RDS_ENDPOINT
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_RDS_PASSWORD
POSTGRES_DB=acp

# Security — generate new values, never reuse dev secrets
JWT_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS
INTERNAL_SECRET=REPLACE_WITH_64_HEX_CHARS
MESH_JWT_SECRET=REPLACE_WITH_64_HEX_CHARS

JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15

# Database passwords (MUST match what you put in init-db.sql)
REGISTRY_DB_PASSWORD=REPLACE_ME_registry_pass
IDENTITY_DB_PASSWORD=REPLACE_ME_identity_pass
AUDIT_DB_PASSWORD=REPLACE_ME_audit_pass
API_DB_PASSWORD=REPLACE_ME_api_pass
USAGE_DB_PASSWORD=REPLACE_ME_usage_pass
IDENTITY_GRAPH_DB_PASSWORD=REPLACE_ME_graph_pass
FLIGHT_RECORDER_DB_PASSWORD=REPLACE_ME_flight_pass
AUTONOMY_DB_PASSWORD=REPLACE_ME_autonomy_pass

# Groq (optional — leave empty if not using)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# OPA
OPA_URL=http://opa:8181
OPA_FAIL_MODE=closed

# Internal service URLs (Docker network — same as dev)
REGISTRY_SERVICE_URL=http://registry:8000
IDENTITY_SERVICE_URL=http://identity:8000
POLICY_SERVICE_URL=http://policy:8000
AUDIT_SERVICE_URL=http://audit:8000
API_SERVICE_URL=http://api:8000
BEHAVIOR_SERVICE_URL=http://behavior:8000
DECISION_SERVICE_URL=http://decision:8000
USAGE_SERVICE_URL=http://usage:8000
INSIGHT_SERVICE_URL=http://insight:8000
FORENSICS_SERVICE_URL=http://forensics:8000
IDENTITY_GRAPH_SERVICE_URL=http://identity_graph:8000
FLIGHT_RECORDER_SERVICE_URL=http://flight_recorder:8000
AUTONOMY_SERVICE_URL=http://autonomy:8000

# Production settings
ENVIRONMENT=production
LOG_LEVEL=WARNING

# CORS — your actual domain
ALLOWED_ORIGINS=https://aegisagent.in,https://www.aegisagent.in

# Alerts (optional but recommended)
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_ME_grafana_strong_password

# Rate limits (production values)
GLOBAL_RATE_LIMIT=100000
IP_RATE_LIMIT=10000
TENANT_RATE_LIMIT=10000
AGENT_RATE_LIMIT=1000
TOKEN_RATE_LIMIT=2000

# S3 backup bucket
S3_BACKUP_BUCKET=acp-backups-prod-am

# Observability (leave empty if not using Jaeger in prod)
OTLP_ENDPOINT=

MAX_CONCURRENT_EXECUTION=500
MAX_PAYLOAD_BYTES=10000
DECISION_GATHER_TOTAL_TIMEOUT=1.5
