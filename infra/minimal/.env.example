# Aegis minimal-mode — secrets template.
#
# Copy to `.env` next to docker-compose.minimal.yml, fill in the
# required values, then `docker compose -f docker-compose.minimal.yml
# up -d`. The .env file MUST NOT be committed to git.
#
# Required (the container refuses to start without these):
#   POSTGRES_PASSWORD   — Postgres superuser password (also used as
#                         the default for every per-service DB role
#                         unless you set them explicitly below)
#   INTERNAL_SECRET     — shared service-to-service secret used by the
#                         gateway → inner services calls. Generate with
#                         `openssl rand -hex 32`.
#   JWT_SECRET_KEY          — HMAC key for signing JWT access tokens.
#                         Generate with `openssl rand -hex 32`.

# ── Required ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=replace-me-with-a-strong-password
INTERNAL_SECRET=replace-me-with-openssl-rand-hex-32
JWT_SECRET_KEY=replace-me-with-openssl-rand-hex-32

# ── Optional — distinct per-service DB credentials ────────────────────
# Leave these unset to share POSTGRES_PASSWORD across all 4 per-DB
# service users (identity / registry / audit / autonomy — behavior is
# Redis-only). Fine for a single-tenant self-host install; set distinct
# vault-rotated values for stricter separation.
# IDENTITY_DB_PASSWORD=...
# REGISTRY_DB_PASSWORD=...
# AUDIT_DB_PASSWORD=...
# AUTONOMY_DB_PASSWORD=...
# (behavior service is Redis-only — no DB password needed)

# ── Optional — Postgres superuser name ────────────────────────────────
# POSTGRES_USER=postgres

# ── Optional — external port the host exposes (defaults to 8000) ──────
# AEGIS_PORT=8000

# ── Optional — environment label, used by the prod-guard ──────────────
# Set to "prod" only if you want the SSM-rooted key provider to refuse
# the LocalFile fallback. For self-host installs the default "self-host"
# label uses the local ed25519 key Aegis generates on first boot.
# AEGIS_ENV=self-host

# ── Optional — Groq live demo agent ───────────────────────────────────
# Set if you want the `/live-demo` page to call a real Groq agent.
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional — PDF compliance bundle export ───────────────────────────
# Enables the PDF format on POST /compliance/export. JSON bundle export
# is always on. Requires reportlab in the image (already bundled).
# AEGIS_PDF_EXPORT_ENABLED=true
