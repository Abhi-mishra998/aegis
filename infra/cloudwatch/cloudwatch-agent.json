{
  "_comment": "sprint-4.D — CloudWatch Logs agent config. Ships every container's stdout/stderr to per-service CloudWatch log groups, indexed by container name and EC2 instance.",
  "_install": "see infra/cloudwatch/install.sh — drop this file at /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json",

  "agent": {
    "run_as_user": "cwagent",
    "metrics_collection_interval": 60
  },

  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/lib/docker/containers/*/*-json.log",
            "log_group_name": "/aegis/docker",
            "log_stream_name": "{instance_id}/{ip_address}/{hostname}",
            "timezone": "UTC",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S.%f%z",
            "auto_removal": false,
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/aegis-backup.log",
            "log_group_name": "/aegis/ops",
            "log_stream_name": "backup/{instance_id}",
            "timezone": "UTC",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/aegis-prune.log",
            "log_group_name": "/aegis/ops",
            "log_stream_name": "prune/{instance_id}",
            "timezone": "UTC",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/aegis-rollback.log",
            "log_group_name": "/aegis/ops",
            "log_stream_name": "rollback/{instance_id}",
            "timezone": "UTC",
            "retention_in_days": 90
          }
        ]
      }
    },
    "log_stream_name": "{instance_id}",
    "force_flush_interval": 15
  }
}
